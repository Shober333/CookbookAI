{
  "name": "cookbookai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:open": "next dev & until nc -z localhost ${PORT:-3000} 2>/dev/null; do sleep 0.5; done && open http://localhost:${PORT:-3000}",
    "dev:kill": "kill $(lsof -ti:${PORT:-3000}) 2>/dev/null || true",
    "build": "next build",
    "build:vercel": "prisma generate --schema prisma-postgres/schema.prisma && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:generate:prod": "prisma generate --schema prisma-postgres/schema.prisma",
    "db:migrate": "node scripts/ensure-sqlite-db.mjs && prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy --schema prisma-postgres/schema.prisma",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.72",
    "@ai-sdk/openai": "^3.0.55",
    "@anthropic-ai/sdk": "^0.91.1",
    "@auth/prisma-adapter": "^2.11.2",
    "@base-ui/react": "^1.4.1",
    "@prisma/client": "^5.22.0",
    "ai": "^6.0.169",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "^15.0.0",
    "next-auth": "^5.0.0-beta.31",
    "ollama-ai-provider": "^1.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "youtube-transcript": "^1.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
