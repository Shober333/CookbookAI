# ============================================
# Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# --- AI / LLM ---
# Choose provider: "ollama" (local/free), "gemini" (production target),
# "groq" (Sprint 7 text provider), or "anthropic" (legacy fallback)
AI_PROVIDER=ollama

# Ollama — install from https://ollama.com, then: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma4:e4b       # local model (requires GPU)
OLLAMA_MODEL=qwen3.5:cloud       # cloud-hosted model (no local GPU needed)
OLLAMA_EXTRACTION_TIMEOUT_MS=120000
# Shared extraction timeout for Gemini/Anthropic/Ollama. Falls back to
# OLLAMA_EXTRACTION_TIMEOUT_MS when unset.
# AI_EXTRACTION_TIMEOUT_MS=120000

# Gemini — Sprint 5 production extraction/adaptation provider
# Required in Vercel when AI_PROVIDER=gemini.
# GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
# Optional retry model for temporary Gemini high-demand/overloaded responses.
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# Groq — required only when AI_PROVIDER=groq. GPT-OSS is text-only; do not use
# this provider for direct video/audio fallback.
# GROQ_API_KEY=your-groq-key
GROQ_MODEL=openai/gpt-oss-120b

# Anthropic — required only when AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Recipe import — keep disabled while validating AI extraction behavior
ENABLE_RECIPE_STRUCTURED_DATA_IMPORT=false

# Browserbase fallback (Sprint 6) — optional, enabled when an API key is set
# unless explicitly disabled with BROWSERBASE_FALLBACK_ENABLED=false. Uses
# paid/usage-metered rendering only for public recipe pages when the normal
# fetch path fails or returns unusable JS-heavy HTML. Do not use it for
# paywalls, logins, CAPTCHA bypass, or private content.
# BROWSERBASE_FALLBACK_ENABLED=false
# BROWSERBASE_API_KEY=your-browserbase-key
# BROWSERBASE_PROJECT_ID=your-browserbase-project-id
BROWSERBASE_REGION=us-east-1
BROWSERBASE_TIMEOUT_MS=30000

# YouTube import (Sprint 3+) — get a key from Google Cloud Console (free tier: 10k units/day).
# Sprint 4 transcript fallback also uses public caption tracks when descriptions
# do not contain a recipe link or recipe-like text.
# YOUTUBE_API_KEY=your-key-here

# Direct AI video fallback (Sprint 7) — optional, disabled by default. Runs only
# after YouTube description links, description text, and public transcript fail.
# Requires a video-capable provider; Gemini is the only supported provider here.
AI_VIDEO_TRANSCRIPTION_ENABLED=false
AI_VIDEO_PROVIDER=gemini
AI_VIDEO_MODEL=gemini-2.5-flash
AI_VIDEO_TIMEOUT_MS=120000

# Nutrition estimates (Sprint 7). FoodData Central is the macro source of
# truth. Optional AI normalization may estimate gram weights for ambiguous
# ingredients, but never authoritative nutrition values.
# FOODDATA_CENTRAL_API_KEY=your-data-gov-key
AI_NUTRITION_NORMALIZATION_ENABLED=false

# --- App ---
AUTH_SECRET=replace-with-openssl-rand-base64-32
# PORT=3000  # Change if 3000 is in use; also update NEXTAUTH_URL to match
NEXTAUTH_URL=http://localhost:3000
# AUTH_URL is required in Vercel/Auth.js deployments and should match
# NEXTAUTH_URL exactly, including https:// and without a trailing slash.
# AUTH_URL=http://localhost:3000

# --- Database ---
DATABASE_URL=file:./dev.db
# Production uses Neon Postgres with prisma-postgres/schema.prisma.
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require
